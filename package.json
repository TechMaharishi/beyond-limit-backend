{
  "name": "server",
  "version": "1.0.0",
  "description": "Express + TypeScript server",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.json src/index.ts",
    "build": "rimraf dist && tsc && tsc-alias",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "typecheck": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc --noEmit"
  },
  "keywords": [
    "express",
    "typescript",
    "pnpm",
    "server"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.12.1",
  "dependencies": {
    "@better-auth/expo": "^1.6.8",
    "@sendgrid/mail": "^8.1.6",
    "better-auth": "^1.6.8",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^13.8.0",
    "helmet": "^8.1.0",
    "mongodb": "^7.2.0",
    "mongoose": "^9.5.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
